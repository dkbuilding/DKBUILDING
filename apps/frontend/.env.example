# Configuration des ports pour DK BUILDING Frontend

# Port du serveur de développement Vite
PORT=5173
FRONTEND_PORT=5173

# URL du backend API
API_URL=http://localhost:3001

# URL de base pour les assets
BASE_URL=http://localhost:5173

# Configuration Cloudinary — DK BUILDING
# Cloud Name (public, peut être exposé dans le frontend)
CLOUDINARY_CLOUD_NAME=votre_cloud_name

# Upload Preset (nécessaire pour uploads unsigned depuis le frontend)
# Créez un preset "Unsigned" dans Cloudinary Dashboard → Settings → Upload → Upload presets
CLOUDINARY_UPLOAD_PRESET=dkbuilding-unsigned

# Dossier par défaut pour organiser les fichiers
CLOUDINARY_FOLDER=dkbuilding
