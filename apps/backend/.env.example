# Configuration pour DK BUILDING API - Version Serverless

# ============================================
# ENVIRONNEMENT
# ============================================
NODE_ENV=development
PORT=3001

# ============================================
# FRONTEND (CORS)
# ============================================
FRONTEND_URL=http://localhost:5173

# ============================================
# TURSO DATABASE (SQLite Cloud)
# ============================================
# Créer un compte sur https://turso.tech
# Commandes:
#   turso auth signup
#   turso db create dk-building-db
#   turso db show dk-building-db --url
#   turso db tokens create dk-building-db

TURSO_DATABASE_URL=libsql://dk-building-db-xxxxx.turso.io
TURSO_AUTH_TOKEN=eyJhbGc...votre_token_ici

# ============================================
# CLOUDINARY (Stockage Fichiers)
# ============================================
# Créer un compte gratuit sur https://cloudinary.com
# Dashboard > Account Details

CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=votre_api_secret

# ============================================
# EMAIL (Resend)
# ============================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@dkbuilding.fr
CONTACT_EMAIL=contact@dkbuilding.fr

# ============================================
# SÉCURITÉ JWT
# ============================================
# Généré avec generateSecurity.js
JWT_SECRET=REMPLACER_PAR_VOTRE_SECRET_GENERE
JWT_SALT=REMPLACER_PAR_VOTRE_SALT_GENERE
JWT_ALGORITHM=sha512
JWT_EXPIRY=30m
JWT_SECURITY_LEVEL=NSA_128_BITS
JWT_VERIFICATION_HASH=REMPLACER_PAR_VOTRE_HASH_GENERE

# ============================================
# MOT DE PASSE HEALTH MONITORING
# ============================================
HEALTH_PASSWORD=REMPLACER_PAR_VOTRE_MOT_DE_PASSE_GENERE
HEALTH_PASSWORD_STRENGTH=5
HEALTH_PASSWORD_ENTROPY=210

# ============================================
# SÉCURITÉ ADMIN - IP WHITELISTING
# ============================================
# Liste des IP autorisées pour l'accès admin (séparées par des virgules)
# En développement: laissez vide pour autoriser toutes les IP
# En production: spécifiez les IP autorisées (ex: 192.168.1.100,203.0.113.42)
ADMIN_ALLOWED_IPS=

# ============================================
# LOCK ACCESS SYSTEM
# ============================================
LOCKACCESS=true
LOCKACCESS_LOCKED=false
LOCKACCESS_MAINTENANCE_MODE=false
LOCKACCESS_ALLOWED_IPS=127.0.0.1,::1
LOCKACCESS_BLOCKED_IPS=

# ============================================
# MÉTADONNÉES DE SÉCURITÉ
# ============================================
SECURITY_GENERATED_AT=2025-10-25T10:21:06.972Z
SECURITY_ALGORITHM=sha512
SECURITY_KEY_LENGTH=512
SECURITY_ITERATIONS=100000
